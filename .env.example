# Quorum API Slice Environment Configuration

# SQLite database relative path from project root
DATABASE_PATH=./orchestrator.db

# Provider List (mock, chatgpt, gemini, claude, etc.)
COUNCIL_PROVIDERS=mock,chatgpt,gemini,claude

# Official API Credentials
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Performance limits
COUNCIL_MAX_CONCURRENCY=2
COUNCIL_MAX_RETRIES=1
COUNCIL_RETRY_BACKOFF_MS=500
REQUIRE_STRUCTURED_REVIEW_CONTEXT=true
